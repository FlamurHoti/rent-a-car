# PostgreSQL from Neon (neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT - string i gjate random (min 32 karaktere)
JWT_SECRET="replace-with-long-random-string-min-32-chars"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV=production

# URL e frontendut ne Vercel
FRONTEND_URL="https://your-app.vercel.app"

# Email (opsionale)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@yourdomain.com"
